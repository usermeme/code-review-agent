# GitHub App
GITHUB_APP_ID=
# Base64-encoded PEM private key of the GitHub App
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Models
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# Storage
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgres://postgres:postgres@localhost:5432/reviews

# Protects the POST /admin/backfill/... endpoint (Bearer token). Required to
# use it — the endpoint returns 503 until this is set. Leave empty to keep the
# admin endpoint disabled.
ADMIN_TOKEN=

# Review philosophy (optional) — path to the code-review skill folder from
# usermeme/skills; empty uses the embedded snapshot
CODE_REVIEW_SKILL_DIR=

# Tickets (optional)
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
CLICKUP_API_TOKEN=
