# Keep the build context small and free of secrets/host artifacts.
.git
.gitignore
node_modules
dist
npm-debug.log*
*.log

# Secrets and local config must never enter the build context or an image layer.
.env
.env.*
!.env.example

# Dev-only files not needed to build or run the image.
test
docs
.github
.vscode
.idea
*.md
!README.md
docker-compose.yml
Dockerfile
.dockerignore
.prettierrc*
.prettierignore
eslint.config.js
