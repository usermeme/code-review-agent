{
  "name": "code-review-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-agent GitHub code-review system built on Google ADK for JavaScript",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "review": "tsx src/commands/review.command.ts",
    "backfill": "tsx src/commands/backfill.command.ts",
    "migrate": "tsx src/commands/migrate.command.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@google/adk": "~1.3.0",
    "@google/genai": "^1.9.0",
    "@octokit/webhooks": "^13.0.0",
    "fastify": "^5.10.0",
    "ioredis": "^5.4.0",
    "js-yaml": "^4.1.0",
    "octokit": "^4.0.0",
    "p-queue": "^8.0.0",
    "pg": "^8.12.0",
    "pino": "^9.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "eslint": "^10.6.0",
    "lefthook": "^2.1.9",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.62.1",
    "vitest": "^2.0.0"
  }
}
